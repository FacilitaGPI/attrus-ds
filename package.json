{
  "name": "@attrus-ds/core",
  "version": "0.2.0",
  "description": "ATTRUS / Cabiros design system — design tokens, component styles, brand assets, fonts and an optional typed React component layer.",
  "keywords": [
    "design-system",
    "design-tokens",
    "attrus",
    "cabiros",
    "css",
    "tokens",
    "fonts",
    "fintech"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FacilitaGPI/attrus-ds.git"
  },
  "homepage": "https://github.com/FacilitaGPI/attrus-ds#readme",
  "bugs": {
    "url": "https://github.com/FacilitaGPI/attrus-ds/issues"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/css/index.css",
    "./css": "./dist/css/index.css",
    "./tokens.css": "./dist/css/tokens.css",
    "./fonts.css": "./dist/css/fonts.css",
    "./tokens.json": "./dist/tokens/attrus-tokens.json",
    "./tokens.flat.json": "./dist/tokens/attrus-tokens.flat.json",
    "./components/*": "./dist/css/components/*",
    "./react": "./dist/react/index.ts",
    "./react/*": "./dist/react/*",
    "./assets/*": "./dist/assets/*",
    "./fonts/*": "./dist/fonts/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@fontsource/jetbrains-mono": "^5.0.0",
    "@fontsource/lato": "^5.0.0"
  }
}
